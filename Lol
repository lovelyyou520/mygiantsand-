                                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game)
                                        task.wait(2)
                                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, game)
                                    else
                                        -- Hold E for 2 seconds on all other coordinates
                                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                                        task.wait(2)
                                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                                    end
                                    
                                    task.wait(2) -- Wait 2 seconds after releasing key
                                end
                            end
                            
                            if not Config.AutoFarm then break end
                            
                            -- 4th location: Dynamic Toaster
                                local toasters = plot:FindFirstChild("Toasters")
                                if toasters then
                                    local toasterObject = toasters:FindFirstChild("Toaster" .. currentToaster)
                                    if toasterObject then
                                        -- Teleport to the CollectionButton1
                                        local collectionFolder = plot:FindFirstChild("CollectionButton")
                                        if collectionFolder then
                                            local collectionBtn = collectionFolder:FindFirstChild("CollectionButton1")
                                            if collectionBtn and collectionBtn:IsA("Model") or collectionBtn:IsA("BasePart") then
                                                pcall(function()
                                                    if collectionBtn:IsA("Model") then
                                                        char.HumanoidRootPart.CFrame = collectionBtn:GetPivot()
                                                    else
                                                        char.HumanoidRootPart.CFrame = collectionBtn.CFrame
                                                    end
                                                end)
                                                task.wait(0.5)
                                            else
                                                triggerNotification("Auto Farm: CollectionButton1 not found! Teleporting to Toaster instead.", Color3.fromRGB(255, 150, 50))
                                                pcall(function() char.HumanoidRootPart.CFrame = toasterObject:GetPivot() end)
                                                task.wait(0.5)
                                            end
                                        else
                                            triggerNotification("Auto Farm: CollectionButton folder not found! Teleporting to Toaster instead.", Color3.fromRGB(255, 150, 50))
                                            pcall(function() char.HumanoidRootPart.CFrame = toasterObject:GetPivot() end)
                                            task.wait(0.5)
                                        end
                                        
                                        local amount = tonumber(Config["ToasterAmount" .. currentToaster]) or 100
                                        if amount > 0 then
                                            triggerNotification("Auto Farm: Duping Toaster " .. currentToaster .. "...", Color3.fromRGB(100, 200, 255))
                                            task.spawn(function()
                                                fireRemoteMultipleTimes(toasterObject, "toasters", amount)
                                            end)
                                        end
                                    else
                                        triggerNotification("Auto Farm: Toaster " .. currentToaster .. " not found! Skipping...", Color3.fromRGB(255, 100, 100))
                                    end
                                else
                                    triggerNotification("Auto Farm: Toasters folder not found!", Color3.fromRGB(255, 100, 100))
                                end
                            
                            -- Cycle to next toaster
                            currentToaster = currentToaster + 1
                            if currentToaster > 5 then
                                currentToaster = 1
                            end
                            
                            -- Wait 2 seconds before restarting the entire cycle
                            task.wait(2)
                        else
                            task.wait(0.5)
                        end
                    else
                        task.wait(0.5)
                    end
                else
                    task.wait(0.5)
                end
            end
        end)
    else
        triggerNotification("Auto Farm Disabled.", Color3.fromRGB(255, 100, 100))
        -- Ensure E key is released if turned off mid-farm
        if VirtualInputManager then
            pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game) end)
        end
    end
end)

