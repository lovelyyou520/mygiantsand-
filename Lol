local StartCookTimerRemote = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("StartCookTimer")

local function findPlayerPlot()
    local plotsFolder = workspace:FindFirstChild("Plots")
    if not plotsFolder then return nil end
    for _, plot in ipairs(plotsFolder:GetChildren()) do
        local ownerId = plot:GetAttribute("OwnerUserId")
        if ownerId and ownerId == LocalPlayer.UserId then
            print("Testing - Found Player Plot:", plot.Name)
            return plot
        end
    end
    return nil
end

local function fireRemoteMultipleTimes(targetObject, remoteType, amount)
    local count = tonumber(amount) or 0
    if count <= 0 then return 0 end
    for _ = 1, count do
        pcall(function()
            StartCookTimerRemote:FireServer(targetObject, remoteType)
        end)
        if _ % 50 == 0 then
            task.wait()
        end
    end
    return count
end

