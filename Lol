local function AddSection(text, defaultOpen)
    if defaultOpen == nil then defaultOpen = false end
    local container = create("Frame", {Size = UDim2.new(1, 0, 0, 0), BackgroundColor3 = Color3.fromRGB(16, 16, 16), BorderSizePixel = 0, ClipsDescendants = true}, mainPage)
    create("UICorner", {CornerRadius = UDim.new(0, 6)}, container)
    create("UIStroke", {Color = Color3.fromRGB(28, 28, 28), Thickness = 1}, container)
    local layout = create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder}, container)
    
    local headerBtn = create("TextButton", {Size = UDim2.new(1, 0, 0, 26), BackgroundColor3 = Color3.fromRGB(10, 10, 10), BorderSizePixel = 0, Text = "", LayoutOrder = 0}, container)
    create("TextLabel", {Size = UDim2.new(1, -30, 1, 0), Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1, Text = "   " .. string.upper(text), TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.GothamBold, TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left}, headerBtn)
    local toggleIcon = create("TextLabel", {Size = UDim2.new(0, 26, 0, 26), Position = UDim2.new(1, -26, 0, 0), BackgroundTransparency = 1, Text = defaultOpen and "▼" or "▶", TextColor3 = Color3.fromRGB(200, 200, 200), Font = Enum.Font.GothamBold, TextSize = 10}, headerBtn)
    
    local divider = create("Frame", {Size = UDim2.new(1, 0, 0, 1), BackgroundColor3 = Color3.fromRGB(28, 28, 28), BorderSizePixel = 0, LayoutOrder = 1, Visible = defaultOpen}, container)
    local content = create("Frame", {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1, LayoutOrder = 2, Visible = defaultOpen}, container)
    local contentLayout = create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder}, content)
    
    local isOpen = defaultOpen
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        container.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y + (isOpen and 4 or 0))
    end)
    contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        content.Size = UDim2.new(1, 0, 0, contentLayout.AbsoluteContentSize.Y)
    end)
    
    headerBtn.MouseButton1Click:Connect(function()
        playClickSound()
        isOpen = not isOpen
        toggleIcon.Text = isOpen and "▼" or "▶"
        divider.Visible = isOpen
        content.Visible = isOpen
        container.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y + (isOpen and 4 or 0))
    end)
    
    return content
end

local function addRowDivider(rowFrame)
    local count = 0
    for _, child in ipairs(rowFrame.Parent:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then count = count + 1 end
    end
    if count > 1 then
        create("Frame", {Size = UDim2.new(1, -20, 0, 1), Position = UDim2.new(0, 10, 0, 0), BackgroundColor3 = Color3.fromRGB(25, 25, 25), BorderSizePixel = 0, ZIndex = 2}, rowFrame)
    end
end

local function AddToggle(parentCard, labelText, configKey, callback)
    local frame = create("Frame", {Size = UDim2.new(1, 0, 0, 34), BackgroundTransparency = 1}, parentCard)
    addRowDivider(frame)
    create("TextLabel", {Size = UDim2.new(0.7, 0, 1, 0), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1, Text = labelText, TextColor3 = Color3.fromRGB(240, 240, 240), Font = Enum.Font.GothamMedium, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left}, frame)
    local switch = create("TextButton", {Size = UDim2.new(0, 34, 0, 16), Position = UDim2.new(1, -44, 0.5, -8), BackgroundColor3 = Color3.fromRGB(30, 30, 30), Text = ""}, frame)
    create("UICorner", {CornerRadius = UDim.new(1, 0)}, switch)
    create("UIStroke", {Color = Color3.fromRGB(45, 45, 45), Thickness = 1}, switch)
    local knob = create("Frame", {Size = UDim2.new(0, 10, 0, 10), Position = UDim2.new(0, 3, 0.5, -5), BackgroundColor3 = Color3.fromRGB(200, 200, 200), BorderSizePixel = 0}, switch)
    create("UICorner", {CornerRadius = UDim.new(1, 0)}, knob)
    local function updateToggleState(state)
        Config[configKey] = state
        local targetPos = state and UDim2.new(1, -13, 0.5, -5) or UDim2.new(0, 3, 0.5, -5)
        local targetBg = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(30, 30, 30)
        local knobBg = state and Color3.fromRGB(10, 10, 10) or Color3.fromRGB(200, 200, 200)
        TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = targetPos, BackgroundColor3 = knobBg}):Play()
        TweenService:Create(switch, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {BackgroundColor3 = targetBg}):Play()
        if callback then callback(state) end
    end
    switch.MouseButton1Click:Connect(function() playClickSound() updateToggleState(not Config[configKey]) end)
    updateToggleState(Config[configKey])
    return frame
end

